---
import PhotoLayout from '../../layouts/PhotoLayout.astro';
import { getCollection } from 'astro:content';

const collections = (await getCollection('collections'))
  .sort((a, b) => a.data.order - b.data.order);
---

<PhotoLayout title="Photos" description="Photography by pkopoku — concerts, portraits, travel.">
  <!-- Hero text -->
  <section class="mb-16">
    <h1 class="font-serif text-6xl md:text-8xl font-black italic leading-none mb-8" style="color: var(--color-paper);">
      Photos
    </h1>
    <div class="max-w-xl flex flex-col gap-4">
      <p class="text-base leading-relaxed" style="color: var(--color-paper-dim);">
        I see the world in scenes. The amber mystery of a fog-drenched street. A silhouette dissolving
        into golden hour. The raw electricity of a concert caught mid-motion — the frame that belongs
        on a screen, not a feed.
      </p>
      <p class="text-base leading-relaxed" style="color: var(--color-paper-dim);">
        The work spans travel, portraits, editorial, and events. The thread through all of it is
        atmosphere: dramatic light, bold shadow, colour that lands before the mind catches up.
      </p>
      <p class="text-base leading-relaxed" style="color: var(--color-paper-dim);">
        If you want something that stops the scroll and stays —&nbsp;<a
          href="https://www.instagram.com/pkopoku"
          class="border-b transition-colors"
          style="color: var(--color-paper); border-color: var(--color-gold);"
        >let's make it</a>.
      </p>
    </div>
  </section>

  <!-- Collections grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px" style="background-color: var(--color-ink-mid);">
    {collections.map((col) => (
      <a
        href={`/photos/${col.data.slug}`}
        class="group relative overflow-hidden aspect-[4/3] block"
        style="background-color: var(--color-ink-soft);"
      >
        <!-- Cover image -->
        <img
          src={col.data.coverImage}
          alt={col.data.title}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-80 group-hover:opacity-60"
          style={`object-position: ${col.data.coverImagePosition};`}
          loading="lazy"
        />

        <!-- Overlay -->
        <div
          class="absolute inset-0 flex flex-col justify-end p-6"
          style="background: linear-gradient(to top, rgba(14,14,14,0.9) 0%, rgba(14,14,14,0.2) 60%, transparent 100%);"
        >
          <span class="font-mono text-xs mb-2" style="color: var(--color-gold);">
            {String(col.data.photos.length).padStart(2, '0')} photos
          </span>
          <h2 class="font-serif text-3xl font-bold" style="color: var(--color-paper);">
            {col.data.title}
          </h2>
          <p class="font-mono text-xs mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="color: var(--color-paper-dim);">
            {col.data.description}
          </p>
        </div>
      </a>
    ))}
  </div>
</PhotoLayout>
