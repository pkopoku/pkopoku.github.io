---
import SWELayout from '../../../layouts/SWELayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<SWELayout title={project.data.title} description={project.data.description}>
  <!-- Back -->
  <a href="/swe/projects" class="font-mono text-xs block mb-16" style="color: var(--color-paper-dim);">
    ← projects
  </a>

  <!-- Header -->
  <header class="mb-16">
    <p class="font-mono text-xs mb-4" style="color: var(--color-gold);">{project.data.year}</p>
    <h1 class="font-serif text-5xl md:text-7xl font-black leading-none mb-6" style="color: var(--color-paper);">
      {project.data.title}
    </h1>
    <p class="text-lg max-w-2xl leading-relaxed mb-8" style="color: var(--color-paper-dim);">
      {project.data.description}
    </p>

    <!-- Tags & Links -->
    <div class="flex flex-wrap items-center gap-4">
      {project.data.tags.map((tag) => (
        <span class="font-mono text-xs px-2 py-1 border" style="border-color: var(--color-ink-mid); color: var(--color-paper-dim);">
          {tag}
        </span>
      ))}
      <span class="flex-1" />
      {project.data.url && (
        <a
          href={project.data.url}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-xs px-4 py-2 border transition-colors hover:bg-[var(--color-gold)] hover:text-[var(--color-ink)] hover:border-[var(--color-gold)]"
          style="border-color: var(--color-paper-dim); color: var(--color-paper-dim);"
        >
          live site ↗
        </a>
      )}
      {project.data.repo && (
        <a
          href={project.data.repo}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-xs px-4 py-2 border transition-colors"
          style="border-color: var(--color-ink-mid); color: var(--color-paper-dim);"
        >
          repo ↗
        </a>
      )}
    </div>
  </header>

  <hr class="section-divider" />

  <!-- Body -->
  <article class="prose-custom max-w-2xl">
    <Content />
  </article>
</SWELayout>

<style>
  .prose-custom :global(h2) {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-paper);
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  .prose-custom :global(p) {
    color: var(--color-paper-dim);
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }
  .prose-custom :global(a) {
    color: var(--color-gold);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-custom :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background-color: var(--color-ink-soft);
    padding: 0.15em 0.4em;
  }
  .prose-custom :global(pre) {
    background-color: var(--color-ink-soft);
    padding: 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
</style>
